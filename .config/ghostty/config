# https://ghostty.org/docs/config

# for true color support
term = xterm-256color

# colors: match alacritty's built-in default palette (base16 default dark).
# ghostty ships a different default theme (blue-gray), so we pin these explicitly.
background = 181818
foreground = d8d8d8
# normal colors (0-7)
palette = 0=#181818
palette = 1=#ac4242
palette = 2=#90a959
palette = 3=#f4bf75
palette = 4=#6a9fb5
palette = 5=#aa759f
palette = 6=#75b5aa
palette = 7=#d8d8d8
# bright colors (8-15)
palette = 8=#6b6b6b
palette = 9=#c55555
palette = 10=#aac474
palette = 11=#feca88
palette = 12=#82b8c8
palette = 13=#c28cb8
palette = 14=#93d3c3
palette = 15=#f8f8f8

# font
# DOWNLOAD HERE: https://www.nerdfonts.com/font-downloads
# must be a "Nerd Font" for icons to work on nvim-tree
font-family = "JetBrainsMonoNL Nerd Font"
font-size = 14

# glyph rendering tuned to match alacritty:
# - 'native' blending is too heavy, 'linear-corrected' is lighter
# - font-thicken adds a little stroke weight back so it isn't too thin
# - negative adjust-cell-width tightens the horizontal spacing
alpha-blending = linear-corrected
font-thicken = true
adjust-cell-width = -3%

# mouse
mouse-hide-while-typing = true

# copy selection straight to the system clipboard (alacritty: save_to_clipboard)
copy-on-select = clipboard

# needed so claude code can paste images from the clipboard (ctrl+v).
clipboard-read = allow

# scrollback. ghostty measures this in bytes, not lines (alacritty used 10000 lines)
scrollback-limit = 10000000

# window
# 'none' disables the titlebar/borders entirely (also disables tabs on macos)
window-decoration = none
maximize = true

# on the first ghostty window (no tmux server running yet), start tmux.
# any window opened after that just gets a plain shell.
# the server is started from an interactive login shell (zsh -lic) so it inherits
# the full .zshrc environment (vars, PATH, etc). this branch only runs once per server.
command = /bin/zsh -l -c "tmux ls &>/dev/null && exec zsh -l || exec zsh -lic 'exec tmux new-session -A -s main'"

# SHIFT+RETURN for a new line (e.g. in claude code)
keybind = shift+enter=text:\n

# automatic updates: download and install on next launch, from the stable channel
auto-update = download
auto-update-channel = stable
