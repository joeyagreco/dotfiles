# https://ghostty.org/docs/config

# for true color support
term = xterm-256color

# colors: match alacritty's built-in default palette (base16 default dark).
# ghostty ships a different default theme (blue-gray), so we pin these explicitly.
background = 181818
foreground = d8d8d8
# normal colors (0-7)
palette = 0=#181818
palette = 1=#ac4242
palette = 2=#90a959
palette = 3=#f4bf75
palette = 4=#6a9fb5
palette = 5=#aa759f
palette = 6=#75b5aa
palette = 7=#d8d8d8
# bright colors (8-15)
palette = 8=#6b6b6b
palette = 9=#c55555
palette = 10=#aac474
palette = 11=#feca88
palette = 12=#82b8c8
palette = 13=#c28cb8
palette = 14=#93d3c3
palette = 15=#f8f8f8

# font
# DOWNLOAD HERE: https://www.nerdfonts.com/font-downloads
# must be a "Nerd Font" for icons to work on nvim-tree
font-family = "JetBrainsMonoNL Nerd Font"
font-size = 14

# glyph rendering
alpha-blending = linear-corrected
font-thicken = true
adjust-cell-width = -3%

# mouse
mouse-hide-while-typing = true

# copy selection straight to the system clipboard 
copy-on-select = clipboard

# use CTRL+V (not cmd+v) to paste images into Claude Code
# also requires ghostty to have macos Accessibility access:
#   System Settings > Privacy & Security > Accessibility > add + enable Ghostty.
# cmd+v can't be made to paste images without breaking normal text paste -- see https://github.com/ghostty-org/ghostty/issues/11444
clipboard-read = allow

# 10,000 lines
scrollback-limit = 10000000

# disables window titlebar/borders/tabs
window-decoration = none
maximize = true

command = /bin/zsh -l -c "tmux ls &>/dev/null && exec zsh -l || exec zsh -lic 'exec tmux new-session -A -s main'"

# SHIFT+RETURN for a new line (used in claude code)
keybind = shift+enter=text:\n

# automatic updates: download and install on next launch, from the stable channel
auto-update = download
auto-update-channel = stable
